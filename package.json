{
  "name": "ux-ui-health-check-framework",
  "version": "1.0.0",
  "scripts": {
    "clean": "rimraf dist",
    "copy-assets": "copyfiles -u 1 \"src/static/**/*\" \"src/modules/audit/email/templates/**/*\" dist",
    "dev": "nodemon src/server.ts",
    "dev:worker": "nodemon src/worker.ts",
    "build": "npm run clean && tsc && npm run copy-assets",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.{ts,js,json,md}\"",
    "prepare": "husky"
  },
  "nodemonConfig": {
    "ignore": [
      "ai_reports/*",
      "final_reports/*",
      "websites_screenshots/*"
    ]
  },
  "dependencies": {
    "@axe-core/puppeteer": "^4.11.1",
    "@types/mongoose": "^5.11.96",
    "axe-core": "^4.10.2",
    "axios": "^1.7.9",
    "broken-link-checker": "^0.7.8",
    "bullmq": "^5.74.1",
    "canvas": "^3.1.0",
    "cheerio": "^1.2.0",
    "chrome-launcher": "^1.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.10.1",
    "jsdom": "^26.0.0",
    "lighthouse": "^12.3.0",
    "mongoose": "^9.4.1",
    "nodemailer": "^8.0.5",
    "openai": "^4.86.1",
    "puppeteer": "^24.3.1",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.17.0",
    "xss-clean": "^0.1.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/hpp": "^0.2.7",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.13.9",
    "@types/nodemailer": "^8.0.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.7",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "copyfiles": "^2.4.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "nodemon": "^3.1.9",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.25.0"
  }
}
